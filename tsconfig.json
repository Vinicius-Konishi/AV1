{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]                  // ← Esta linha resolve os erros de 'readline', 'process', 'fs' e 'path'
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}